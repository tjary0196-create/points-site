{
  "rewrites": [
    {
      "source": "/((?!tournaments.html|admin.html|404.html|sw.js|manifest.json|.*\\.css|.*\\.js|.*\\.png|.*\\.jpg|.*\\.svg).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ]
}
