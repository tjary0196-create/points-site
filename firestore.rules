rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (
        isOwner(userId) && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'fullName', 'contact', 'avatarUrl', 'referredBy', 'updatedAt']) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'totalSpent', 'pendingReward', 'claimedReward']))
        )
      ) || (
        isSignedIn() &&
        userId != request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) &&
        request.resource.data.balance > resource.data.balance
      );
    }

    match /rechargeCodes/{code} {
      allow read: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.used == false
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedAt'])
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.used == true;
      allow create, delete: if isAdmin();
    }

    match /admins/{admin} { allow read, write: if isAdmin(); }
    match /apiSources/{source} { allow read, write: if isAdmin(); }

    match /orders/{order} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /products/{prodId} { allow read: if true; allow write: if isAdmin(); }
    match /ads/{adId} { allow read: if true; allow write: if isAdmin(); }

    match /loyaltySettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /auctions/{auctionId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(resource.data.sellerUid) || isSignedIn();
      allow delete: if isAdmin();

      match /bids/{bidId} {
        allow read: if isAdmin();
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /referralCodes/{code} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /tournaments/{tId} { allow read: if true; allow write: if isAdmin(); }
    match /tournamentRegistrations/{regId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
